datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  CITIZEN
  ADMIN
}

enum OfficerRole {
  OFFICER
  DEPT_HEAD
}

enum ComplaintStatus {
  PENDING
  IN_PROGRESS
  RESOLVED
  REJECTED
}

enum Severity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum NotificationType {
  INFO
  ALERT
  UPDATE
}

enum ActorType {
  USER
  OFFICER
  SYSTEM
}

model User {
  id            String         @id @default(uuid())
  username      String         @unique
  phone         String?        @unique
  passwordHash  String
  name          String
  role          Role           @default(CITIZEN)
  status        String         @default("ACTIVE") // ACTIVE, SUSPENDED
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  complaints    Complaint[]
  notifications Notification[]
  refreshTokens RefreshToken[]
}

model Department {
  id          String      @id @default(uuid())
  name        String      @unique
  description String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  officers    Officer[]
  complaints  Complaint[]
}

model Officer {
  id            String         @id @default(uuid())
  username      String         @unique
  passwordHash  String
  name          String
  role          OfficerRole    @default(OFFICER)
  status        String         @default("ACTIVE") // ACTIVE, SUSPENDED
  departmentId  String
  department    Department     @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  complaints    Complaint[]    @relation("AssignedComplaints")
  notifications Notification[]
  refreshTokens RefreshToken[]
}

model Complaint {
  id            String          @id @default(uuid())
  title         String
  description   String
  category      String
  latitude      Float
  longitude     Float
  address       String
  status        ComplaintStatus @default(PENDING)
  severity      Severity        @default(MEDIUM)
  userId        String
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  departmentId  String?
  department    Department?     @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  officerId     String?
  officer       Officer?        @relation("AssignedComplaints", fields: [officerId], references: [id], onDelete: SetNull)
  images        Image[]
  aiAnalysis    AIAnalysis?
  statusHistory StatusHistory[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model Image {
  id          String    @id @default(uuid())
  url         String
  complaintId String
  complaint   Complaint @relation(fields: [complaintId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
}

model AIAnalysis {
  id              String    @id @default(uuid())
  complaintId     String    @unique
  complaint       Complaint @relation(fields: [complaintId], references: [id], onDelete: Cascade)
  summary         String
  tags            Json      // String array of tags
  confidenceScore Float     @default(0.0)
  detectedSeverity Severity  @default(MEDIUM)
  processedAt     DateTime  @default(now())
}

model Notification {
  id        String           @id @default(uuid())
  title     String
  message   String
  type      NotificationType @default(INFO)
  isRead    Boolean          @default(false)
  userId    String?
  user      User?            @relation(fields: [userId], references: [id], onDelete: Cascade)
  officerId String?
  officer   Officer?         @relation(fields: [officerId], references: [id], onDelete: Cascade)
  createdAt DateTime         @default(now())
}

model StatusHistory {
  id             String          @id @default(uuid())
  complaintId    String
  complaint      Complaint       @relation(fields: [complaintId], references: [id], onDelete: Cascade)
  previousStatus ComplaintStatus
  newStatus      ComplaintStatus
  remarks        String?
  changedById    String
  changedByType  ActorType       @default(SYSTEM)
  createdAt      DateTime        @default(now())
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  officerId String?
  officer   Officer? @relation(fields: [officerId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model AuditLog {
  id             String    @id @default(uuid())
  action         String
  details        String
  performedById  String?
  performedByType ActorType @default(SYSTEM)
  ipAddress      String?
  createdAt      DateTime  @default(now())
}
